{
  "expo": {
    "name": "FlagOn",
    "slug": "flagon",
    "scheme": "flagon",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2D6A4F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.flagOn.app",
      "buildNumber": "9",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "정상 GPS 인증을 위해 위치 정보를 사용합니다.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "등산 중 GPS 트래킹을 위해 백그라운드 위치 접근이 필요합니다.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "usesAppleSignIn": true,
      "entitlements": {
        "com.apple.developer.applesignin": ["Default"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "정상 GPS 인증을 위해 위치 정보를 사용합니다.",
          "locationAlwaysAndWhenInUsePermission": "등산 중 GPS 트래킹을 위해 백그라운드 위치 접근이 필요합니다."
        }
      ],
      "@maplibre/maplibre-react-native",
      [
        "expo-notifications",
        {
          "iosPermissionPreamble": "정상 근처 알림 및 크루 깃발 탈취 알림을 받으려면 알림을 허용하세요."
        }
      ],
      "expo-build-properties",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "f16f657c-585b-41be-853b-016aa128c682"
      }
    },
    "owner": "nahmon"
  }
}
